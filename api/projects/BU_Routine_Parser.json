83 0l2.5-2.5a2.002 2.002 0 0 0-2.83-2.83l-1.25 1.25a.751.751 0 0 1-1.042-.018.751.751 0 0 1-.018-1.042Zm-4.69 9.64a1.998 1.998 0 0 0 2.83 0l1.25-1.25a.751.751 0 0 1 1.042.018.751.751 0 0 1 .018 1.042l-1.25 1.25a3.5 3.5 0 1 1-4.95-4.95l2.5-2.5a3.5 3.5 0 0 1 4.95 0 .751.751 0 0 1-.018 1.042.751.751 0 0 1-1.042.018 1.998 1.998 0 0 0-2.83 0l-2.5 2.5a1.998 1.998 0 0 0 0 2.83Z\"></path></svg></a></div>\n<p dir=\"auto\">This template provides a minimal setup to get React working in Vite with HMR and some ESLint rules.</p>\n<p dir=\"auto\">Currently, two official plugins are available:</p>\n<ul dir=\"auto\">\n<li><a href=\"https://github.com/vitejs/vite-plugin-react/blob/main/packages/plugin-react\">@vitejs/plugin-react</a> uses <a href=\"https://babeljs.io/\" rel=\"nofollow\">Babel</a> (or <a href=\"https://oxc.rs\" rel=\"nofollow\">oxc</a> when used in <a href=\"https://vite.dev/guide/rolldown\" rel=\"nofollow\">rolldown-vite</a>) for Fast Refresh</li>\n<li><a href=\"https://github.com/vitejs/vite-plugin-react/blob/main/packages/plugin-react-swc\">@vitejs/plugin-react-swc</a> uses <a href=\"https://swc.rs/\" rel=\"nofollow\">SWC</a> for Fast Refresh</li>\n</ul>\n<div class=\"markdown-heading\" dir=\"auto\"><h2 class=\"heading-element\" dir=\"auto\">React Compiler</h2><a id=\"user-content-react-compiler\" class=\"anchor\" aria-label=\"Permalink: React Compiler\" href=\"#react-compiler\"><svg data-component=\"Octicon\" class=\"octicon octicon-link\" viewBox=\"0 0 16 16\" version=\"1.1\" width=\"16\" height=\"16\" aria-hidden=\"true\"><path d=\"m7.775 3.275 1.25-1.25a3.5 3.5 0 1 1 4.95 4.95l-2.5 2.5a3.5 3.5 0 0 1-4.95 0 .751.751 0 0 1 .018-1.042.751.751 0 0 1 1.042-.018 1.998 1.998 0 0 0 2.83 0l2.5-2.5a2.002 2.002 0 0 0-2.83-2.83l-1.25 1.25a.751.751 0 0 1-1.042-.018.751.751 0 0 1-.018-1.042Zm-4.69 9.64a1.998 1.998 0 0 0 2.83 0l1.25-1.25a.751.751 0 0 1 1.042.018.751.751 0 0 1 .018 1.042l-1.25 1.25a3.5 3.5 0 1 1-4.95-4.95l2.5-2.5a3.5 3.5 0 0 1 4.95 0 .751.751 0 0 1-.018 1.042.751.751 0 0 1-1.042.018 1.998 1.998 0 0 0-2.83 0l-2.5 2.5a1.998 1.998 0 0 0 0 2.83Z\"></path></svg></a></div>\n<p dir=\"auto\">The React Compiler is currently not compatible with SWC. See <a href=\"https://github.com/vitejs/vite-plugin-react/issues/428\" data-hovercard-type=\"issue\" data-hovercard-url=\"/vitejs/vite-plugin-react/issues/428/hovercard\">this issue</a> for tracking the progress.</p>\n<div class=\"markdown-heading\" dir=\"auto\"><h2 class=\"heading-element\" dir=\"auto\">Expanding the ESLint configuration</h2><a id=\"user-content-expanding-the-eslint-configuration\" class=\"anchor\" aria-label=\"Permalink: Expanding the ESLint configuration\" href=\"#expanding-the-eslint-configuration\"><svg data-component=\"Octicon\" class=\"octicon octicon-link\" viewBox=\"0 0 16 16\" version=\"1.1\" width=\"16\" height=\"16\" aria-hidden=\"true\"><path d=\"m7.775 3.275 1.25-1.25a3.5 3.5 0 1 1 4.95 4.95l-2.5 2.5a3.5 3.5 0 0 1-4.95 0 .751.751 0 0 1 .018-1.042.751.751 0 0 1 1.042-.018 1.998 1.998 0 0 0 2.83 0l2.5-2.5a2.002 2.002 0 0 0-2.83-2.83l-1.25 1.25a.751.751 0 0 1-1.042-.018.751.751 0 0 1-.018-1.042Zm-4.69 9.64a1.998 1.998 0 0 0 2.83 0l1.25-1.25a.751.751 0 0 1 1.042.018.751.751 0 0 1 .018 1.042l-1.25 1.25a3.5 3.5 0 1 1-4.95-4.95l2.5-2.5a3.5 3.5 0 0 1 4.95 0 .751.751 0 0 1-.018 1.042.751.751 0 0 1-1.042.018 1.998 1.998 0 0 0-2.83 0l-2.5 2.5a1.998 1.998 0 0 0 0 2.83Z\"></path></svg></a></div>\n<p dir=\"auto\">If you are developing a production application, we recommend updating the configuration to enable type-aware lint rules:</p>\n<div class=\"highlight highlight-source-js notranslate position-relative overflow-auto\" dir=\"auto\" data-snippet-clipboard-copy-content=\"export default defineConfig([\n  globalIgnores(['dist']),\n  {\n    files: ['**/*.{ts,tsx}'],\n    extends: [\n      // Other configs...\n\n      // Remove tseslint.configs.recommended and replace with this\n      tseslint.configs.recommendedTypeChecked,\n      // Alternatively, use this for stricter rules\n      tseslint.configs.strictTypeChecked,\n      // Optionally, add this for stylistic rules\n      tseslint.configs.stylisticTypeChecked,\n\n      // Other configs...\n    ],\n    languageOptions: {\n      parserOptions: {\n        project: ['./tsconfig.node.json', './tsconfig.app.json'],\n        tsconfigRootDir: import.meta.dirname,\n      },\n      // other options...\n    },\n  },\n])\"><pre><span class=\"pl-k\">export</span> <span class=\"pl-k\">default</span> <span class=\"pl-en\">defineConfig</span><span class=\"pl-kos\">(</span><span class=\"pl-kos\">[</span>\n  <span class=\"pl-en\">globalIgnores</span><span class=\"pl-kos\">(</span><span class=\"pl-kos\">[</span><span class=\"pl-s\">'dist'</span><span class=\"pl-kos\">]</span><span class=\"pl-kos\">)</span><span class=\"pl-kos\">,</span>\n  <span class=\"pl-kos\">{</span>\n    <span class=\"pl-c1\">files</span>: <span class=\"pl-kos\">[</span><span class=\"pl-s\">'**/*.{ts,tsx}'</span><span class=\"pl-kos\">]</span><span class=\"pl-kos\">,</span>\n    <span class=\"pl-c1\">extends</span>: <span class=\"pl-kos\">[</span>\n      <span class=\"pl-c\">// Other configs...</span>\n\n      <span class=\"pl-c\">// Remove tseslint.configs.recommended and replace with this</span>\n      <span class=\"pl-s1\">tseslint</span><span class=\"pl-kos\">.</span><span class=\"pl-c1\">configs</span><span class=\"pl-kos\">.</span><span class=\"pl-c1\">recommendedTypeChecked</span><span class=\"pl-kos\">,</span>\n      <span class=\"pl-c\">// Alternatively, use this for stricter rules</span>\n      <span class=\"pl-s1\">tseslint</span><span class=\"pl-kos\">.</span><span class=\"pl-c1\">configs</span><span class=\"pl-kos\">.</span><span class=\"pl-c1\">strictTypeChecked</span><span class=\"pl-kos\">,</span>\n      <span class=\"pl-c\">// Optionally, add this for stylistic rules</span>\n      <span class=\"pl-s1\">tseslint</span><span class=\"pl-kos\">.</span><span class=\"pl-c1\">configs</span><span class=\"pl-kos\">.</span><span class=\"pl-c1\">stylisticTypeChecked</span><span class=\"pl-kos\">,</span>\n\n      <span class=\"pl-c\">// Other configs...</span>\n    <span class=\"pl-kos\">]</span><span class=\"pl-kos\">,</span>\n    <span class=\"pl-c1\">languageOptions</span>: <span class=\"pl-kos\">{</span>\n      <span class=\"pl-c1\">parserOptions</span>: <span class=\"pl-kos\">{</span>\n        <span class=\"pl-c1\">project</span>: <span class=\"pl-kos\">[</span><span class=\"pl-s\">'./tsconfig.node.json'</span><span class=\"pl-kos\">,</span> <span class=\"pl-s\">'./tsconfig.app.json'</span><span class=\"pl-kos\">]</span><span class=\"pl-kos\">,</span>\n        <span class=\"pl-c1\">tsconfigRootDir</span>: <span class=\"pl-k\">import</span><span class=\"pl-kos\">.</span>meta<span class=\"pl-kos\">.</span><span class=\"pl-c1\">dirname</span><span class=\"pl-kos\">,</span>\n      <span class=\"pl-kos\">}</span><span class=\"pl-kos\">,</span>\n      <span class=\"pl-c\">// other options...</span>\n    <span class=\"pl-kos\">}</span><span class=\"pl-kos\">,</span>\n  <span class=\"pl-kos\">}</span><span class=\"pl-kos\">,</span>\n<span class=\"pl-kos\">]</span><span class=\"pl-kos\">)</span></pre></div>\n<p dir=\"auto\">You can also install <a href=\"https://github.com/Rel1cx/eslint-react/tree/main/packages/plugins/eslint-plugin-react-x\">eslint-plugin-react-x</a> and <a href=\"https://github.com/Rel1cx/eslint-react/tree/main/packages/plugins/eslint-plugin-react-dom\">eslint-plugin-react-dom</a> for React-specific lint rules:</p>\n<div class=\"highlight highlight-source-js notranslate position-relative overflow-auto\" dir=\"auto\" data-snippet-clipboard-copy-content=\"// eslint.config.js\nimport reactX from 'eslint-plugin-react-x'\nimport reactDom from 'eslint-plugin-react-dom'\n\nexport default defineConfig([\n  globalIgnores(['dist']),\n  {\n    files: ['**/*.{ts,tsx}'],\n    extends: [\n      // Other configs...\n      // Enable lint rules for React\n      reactX.configs['recommended-typescript'],\n      // Enable lint rules for React DOM\n      reactDom.configs.recommended,\n    ],\n    languageOptions: {\n      parserOptions: {\n        project: ['./tsconfig.node.json', './tsconfig.app.json'],\n        tsconfigRootDir: import.meta.dirname,\n      },\n      // other options...\n    },\n  },\n])\"><pre><span class=\"pl-c\">// eslint.config.js</span>\n<span class=\"pl-k\">import</span> <span class=\"pl-s1\">reactX</span> <span class=\"pl-k\">from</span> <span class=\"pl-s\">'eslint-plugin-react-x'</span>\n<span class=\"pl-k\">import</span> <span class=\"pl-s1\">reactDom</span> <span class=\"pl-k\">from</span> <span class=\"pl-s\">'eslint-plugin-react-dom'</span>\n\n<span class=\"pl-k\">export</span> <span class=\"pl-k\">default</span> <span class=\"pl-en\">defineConfig</span><span class=\"pl-kos\">(</span><span class=\"pl-kos\">[</span>\n  <span class=\"pl-en\">globalIgnores</span><span class=\"pl-kos\">(</span><span class=\"pl-kos\">[</span><span class=\"pl-s\">'dist'</span><span class=\"pl-kos\">]</span><span class=\"pl-kos\">)</span><span class=\"pl-kos\">,</span>\n  <span class=\"pl-kos\">{</span>\n    <span class=\"pl-c1\">files</span>: <span class=\"pl-kos\">[</span><span class=\"pl-s\">'**/*.{ts,tsx}'</span><span class=\"pl-kos\">]</span><span class=\"pl-kos\">,</span>\n    <span class=\"pl-c1\">extends</span>: <span class=\"pl-kos\">[</span>\n      <span class=\"pl-c\">// Other configs...</span>\n      <span class=\"pl-c\">// Enable lint rules for React</span>\n      <span class=\"pl-s1\">reactX</span><span class=\"pl-kos\">.</span><span class=\"pl-c1\">configs</span><span class=\"pl-kos\">[</span><span class=\"pl-s\">'recommended-typescript'</span><span class=\"pl-kos\">]</span><span class=\"pl-kos\">,</span>\n      <span class=\"pl-c\">// Enable lint rules for React DOM</span>\n      <span class=\"pl-s1\">reactDom</span><span class=\"pl-kos\">.</span><span class=\"pl-c1\">configs</span><span class=\"pl-kos\">.</span><span class=