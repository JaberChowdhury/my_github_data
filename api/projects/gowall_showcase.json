{"id":1010297591,"name":"gowall_showcase","description":"A simple Node.js photo gallery with theme support, image grouping, and dashboard analytics.","html_url":"https://github.com/JaberChowdhury/gowall_showcase","homepage":"","language":"JavaScript","topics":["css","gowall","html","image-processing","javascript","nodejs","windows"],"stargazers_count":0,"updated_at":"2025-07-27T15:50:41Z","full_name":"JaberChowdhury/gowall_showcase","watchers_count":0,"forks_count":0,"pushed_at":"2025-07-27T15:50:38Z","default_branch":"master","fork":false,"size":8028,"open_issues_count":0,"branches":[{"name":"master","commit":{"sha":"b104a1b2ab90bbad7c61b2f2a9680ab74826c4f5","url":"https://api.github.com/repos/JaberChowdhury/gowall_showcase/commits/b104a1b2ab90bbad7c61b2f2a9680ab74826c4f5"},"protected":false,"languages":{"Markdown":1,"JavaScript":8,"Shell":1,"JSON":2,"CSS":2},"recentCommits":[{"sha":"b104a1b2ab90bbad7c61b2f2a9680ab74826c4f5","message":"add && update : a sh file and update package.json file","author":"black","date":"2025-07-27T15:50:27Z","url":"https://github.com/JaberChowdhury/gowall_showcase/commit/b104a1b2ab90bbad7c61b2f2a9680ab74826c4f5"},{"sha":"862c691412c9b3bd763947b32ba52f542ac2434b","message":"Add support for additional themes and update theme switcher logic","author":"black","date":"2025-06-28T19:33:04Z","url":"https://github.com/JaberChowdhury/gowall_showcase/commit/862c691412c9b3bd763947b32ba52f542ac2434b"},{"sha":"79febe516bc3fb63d7e015ecd5c0be4f9bd294fd","message":"Add screenshot section to README.md","author":"black","date":"2025-06-28T19:17:44Z","url":"https://github.com/JaberChowdhury/gowall_showcase/commit/79febe516bc3fb63d7e015ecd5c0be4f9bd294fd"},{"sha":"a84bb6d579f00fbe07f88098e31f9045b052bac2","message":"Add initial README.md with setup instructions and usage guidelines","author":"black","date":"2025-06-28T19:12:51Z","url":"https://github.com/JaberChowdhury/gowall_showcase/commit/a84bb6d579f00fbe07f88098e31f9045b052bac2"},{"sha":"3597dc07f24822