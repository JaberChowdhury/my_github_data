Z","url":"https://github.com/JaberChowdhury/grub-of-tsushima/commit/5cafdfad76bcb110d62c716746631459009b0bad"}]},{"name":"master","commit":{"sha":"e8d476dcfe7c9462bda29f9442ef703202990fae","url":"https://api.github.com/repos/JaberChowdhury/grub-of-tsushima/commits/e8d476dcfe7c9462bda29f9442ef703202990fae"},"protected":false,"languages":{"Markdown":1},"recentCommits":[{"sha":"e8d476dcfe7c9462bda29f9442ef703202990fae","message":"Fixed link for Black variant font in README","author":"Ivan Immanuel","date":"2026-05-04T19:24:15Z","url":"https://github.com/JaberChowdhury/grub-of-tsushima/commit/e8d476dcfe7c9462bda29f9442ef703202990fae"},{"sha":"7ffee2865a982830e7b960d0ff2c122cf8db7793","message":"Updated README\n\nUpdated README to improve clarity and formatting.","author":"Ivan Immanuel","date":"2026-05-04T05:43:40Z","url":"https://github.com/JaberChowdhury/grub-of-tsushima/commit/7ffee2865a982830e7b960d0ff2c122cf8db7793"},{"sha":"5cafdfad76bcb110d62c716746631459009b0bad","message":"Updated README","author":"Ivan Immanuel","date":"2026-05-04T05:28:41Z","url":"https://github.com/JaberChowdhury/grub-of-tsushima/commit/5cafdfad76bcb110d62c716746631459009b0bad"},{"sha":"1ddd3f5ba61a56a2178039fd36c1211f85e46956","message":"Added white variant","author":"Ivan Immanuel","date":"2026-05-04T05:27:04Z","url":"https://github.com/JaberChowdhury/grub-of-tsushima/commit/1ddd3f5ba61a56a2178039fd36c1211f85e46956"},{"sha":"72dbc02c1af85cc28fa9cc50e1d80f89ed507f87","message":"Refactored theme file","author":"Ivan Immanuel","date":"2026-05-04T05:21:18Z","url":"https://github.com/JaberChowdhury/grub-of-tsushima/commit/72dbc02c1af85cc28fa9cc50e1d80f89ed507f87"}]}],"readmes":[{"name":"master","readmeHtml":"<div id=\"readme\" class=\"md\" data-path=\"README.md\"><article class=\"markdown-body entry-content container-lg\" itemprop=\"text\"><div class=\"markdown-heading\" dir=\"auto\"><h1 class=\"heading-element\" dir=\"auto\">Grub of Tsushima</h1><a id=\"user-content-grub-of-tsushima\" class=\"anchor\" aria-label=\"Permalink: Grub of Tsushima\" href=\"#grub-of-tsushima\"><svg data-component=\"Octicon\" class=\"octicon octicon-link\" viewBox=\"0 0 16 16\" version=\"1.1\" width=\"16\" height=\"16\" aria-hidden=\"true\"><path d=\"m7.775 3.275 1.25-1.25a3.5 3.5 0 1 1 4.95 4.95l-2.5 2.5a3.5 3.5 0 0 1-4.95 0 .751.751 0 0 1 .018-1.042.751.751 0 0 1 1.042-.018 1.998 1.998 0 0 0 2.83 0l2.5-2.5a2.002 2.002 0 0 0-2.83-2.83l-1.25 1.25a.751.751 0 0 1-1.042-.018.751.751 0 0 1-.018-1.042Zm-4.69 9.64a1.998 1.998 0 0 0 2.83 0l1.25-1.25a.751.751 0 0 1 1.042.018.751.751 0 0 1 .018 1.042l-1.25 1.25a3.5 3.5 0 1 1-4.95-4.95l2.5-2.5a3.5 3.5 0 0 1 4.95 0 .751.751 0 0 1-.018 1.042.751.751 0 0 1-1.042.018 1.998 1.998 0 0 0-2.83 0l-2.5 2.5a1.998 1.998 0 0 0 0 2.83Z\"></path></svg></a></div>\n<p dir=\"auto\">A GRUB2 bootloader theme inspired by <strong>Ghost of Tsushima</strong> — with two variants to choose from. This theme was written for a resolution of 1920x1080, other resolutions may require adjustments to theme.txt.</p>\n<div class=\"markdown-heading\" dir=\"auto\"><h2 class=\"heading-element\" dir=\"auto\">Variants</h2><a id=\"user-content-variants\" class=\"anchor\" aria-label=\"Permalink: Variants\" href=\"#variants\"><svg data-component=\"Octicon\" class=\"octicon octicon-link\" viewBox=\"0 0 16 16\" version=\"1.1\" width=\"16\" height=\"16\" aria-hidden=\"true\"><path d=\"m7.775 3.275 1.25-1.25a3.5 3.5 0 1 1 4.95 4.95l-2.5 2.5a3.5 3.5 0 0 1-4.95 0 .751.751 0 0 1 .018-1.042.751.751 0 0 1 1.042-.018 1.998 1.998 0 0 0 2.83 0l2.5-2.5a2.002 2.002 0 0 0-2.83-2.83l-1.25 1.25a.751.751 0 0 1-1.042-.018.751.751 0 0 1-.018-1.042Zm-4.69 9.64a1.998 1.998 0 0 0 2.83 0l1.25-1.25a.751.751 0 0 1 1.042.018.751.751 0 0 1 .018 1.042l-1.25 1.25a3.5 3.5 0 1 1-4.95-4.95l2.5-2.5a3.5 3.5 0 0 1 4.95 0 .751.751 0 0 1-.018 1.042.751.751 0 0 1-1.042.018 1.998 1.998 0 0 0-2.83 0l-2.5 2.5a1.998 1.998 0 0 0 0 2.83Z\"></path></svg></a></div>\n<div class=\"markdown-heading\" dir=\"auto\"><h3 class=\"heading-element\" dir=\"auto\"><em>Ghost of Tsushima</em> - White (faithful to the game)</h3><a id=\"user-content-ghost-of-tsushima---white-faithful-to-the-game\" class=\"anchor\" aria-label=\"Permalink: Ghost of Tsushima - White (faithful to the game)\" href=\"#ghost-of-tsushima---white-faithful-to-the-game\"><svg data-component=\"Octicon\" class=\"octicon octicon-link\" viewBox=\"0 0 16 16\" version=\"1.1\" width=\"16\" height=\"16\" aria-hidden=\"true\"><path d=\"m7.775 3.275 1.25-1.25a3.5 3.5 0 1 1 4.95 4.95l-2.5 2.5a3.5 3.5 0 0 1-4.95 0 .751.751 0 0 1 .018-1.042.751.751 0 0 1 1.042-.018 1.998 1.998 0 0 0 2.83 0l2.5-2.5a2.002 2.002 0 0 0-2.83-2.83l-1.25 1.25a.751.751 0 0 1-1.042-.018.751.751 0 0 1-.018-1.042Zm-4.69 9.64a1.998 1.998 0 0 0 2.83 0l1.25-1.25a.751.751 0 0 1 1.042.018.751.751 0 0 1 .018 1.042l-1.25 1.25a3.5 3.5 0 1 1-4.95-4.95l2.5-2.5a3.5 3.5 0 0 1 4.95 0 .751.751 0 0 1-.018 1.042.751.751 0 0 1-1.042.018 1.998 1.998 0 0 0-2.83 0l-2.5 2.5a1.998 1.998 0 0 0 0 2.83Z\"></path></svg></a></div>\n<p dir=\"auto\">Clean, minimal, no icons. Closely matches the actual GoT menu screen.</p>\n<p dir=\"auto\"><a target=\"_blank\" rel=\"noopener noreferrer\" href=\"preview-white.jpg\"><img src=\"preview-white.jpg\" alt=\"preview-white\" style=\"max-width: 100%;\"></a></p>\n<div class=\"markdown-heading\" dir=\"auto\"><h3 class=\"heading-element\" dir=\"auto\"><em>Ghost of Tsushima</em> - Black</h3><a id=\"user-content-ghost-of-tsushima---black\" class=\"anchor\" aria-label=\"Permalink: Ghost of Tsushima - Black\" href=\"#ghost-of-tsushima---black\"><svg data-component=\"Octicon\" class=\"octicon octicon-link\" viewBox=\"0 0 16 16\" version=\"1.1\" width=\"16\" height=\"16\" aria-hidden=\"true\"><path d=\"m7.775 3.275 1.25-1.25a3.5 3.5 0 1 1 4.95 4.95l-2.5 2.5a3.5 3.5 0 0 1-4.95 0 .751.751 0 0 1 .018-1.042.751.751 0 0 1 1.042-.018 1.998 1.998 0 0 0 2.83 0l2.5-2.5a2.002 2.002 0 0 0-2.83-2.83l-1.25 1.25a.751.751 0 0 1-1.042-.018.751.751 0 0 1-.018-1.042Zm-4.69 9.64a1.998 1.998 0 0 0 2.83 0l1.25-1.25a.751.751 0 0 1 1.042.018.751.751 0 0 1 .018 1.042l-1.25 1.25a3.5 3.5 0 1 1-4.95-4.95l2.5-2.5a3.5 3.5 0 0 1 4.95 0 .751.751 0 0 1-.018 1.042.751.751 0 0 1-1.042.018 1.998 1.998 0 0 0-2.83 0l-2.5 2.5a1.998 1.998 0 0 0 0 2.83Z\"></path></svg></a></div>\n<p dir=\"auto\">The original version of the theme with included icons.</p>\n<p dir=\"auto\"><a target=\"_blank\" rel=\"noopener noreferrer\" href=\"preview-black.jpg\"><img src=\"preview-black.jpg\" alt=\"preview-black\" style=\"max-width: 100%;\"></a></p>\n<div class=\"markdown-heading\" dir=\"auto\"><h2 class=\"heading-element\" dir=\"auto\">Installation</h2><a id=\"user-content-installation\" class=\"anchor\" aria-label=\"Permalink: Installation\" href=\"#installation\"><svg data-component=\"Octicon\" class=\"octicon octicon-link\" viewBox=\"0 0 16 16\" version=\"1.1\" width=\"16\" height=\"16\" aria-hidden=\"true\"><path d=\"m7.775 3.275 1.25-1.25a3.5 3.5 0 1 1 4.95 4.95l-2.5 2.5a3.5 3.5 0 0 1-4.95 0 .751.751 0 0 1 .018-1.042.751.751 0 0 1 1.042-.018 1.998 1.998 0 0 0 2.83 0l2.5-2.5a2.002 2.002 0 0 0-2.83-2.83l-1.25 1.25a.751.751 0 0 1-1.042-.018.751.751 0 0 1-.018-1.042Zm-4.69 9.64a1.998 1.998 0 0 0 2.83 0l1.25-1.25a.751.751 0 0 1 1.042.018.751.751 0 0 1 .018 1.042l-1.25 1.25a3.5 3.5 0 1 1-4.95-4.95l2.5-2.5a3.5 3.5 0 0 1 4.95 0 .751.751 0 0 1-.018 1.042.751.751 0 0 1-1.042.018 1.998 1.998 0 0 0-2.83 0l-2.5 2.5a1.998 1.998 0 0 0 0 2.83Z\"></path></svg></a></div>\n<ol dir=\"auto\">\n<li>Clone the repo or download the zip:</li>\n</ol>\n<div class=\"highlight highlight-source-shell notranslate position-relative overflow-auto\" dir=\"auto\" data-snippet-clipboard-copy-content=\"git clone https://github.com/ivanimmanuel-dev/grub-of-tsushima\"><pre>git clone https://github.com/ivanimmanuel-dev/grub-of-tsushima</pre></div>\n<ol start=\"2\" dir=\"auto\">\n<li>Copy your preferred variant to your GRUB themes directory:</li>\n</ol>\n<div class=\"highlight highlight-source-shell notranslate position-relative overflow-auto\" dir=\"auto\" data-snippet-clipboard-copy-content=\"# For the white variant:\nsudo cp -r grub-of-tsushima/grub-of-tsushima-white /boot/grub/themes/grub-of-tsushima\n\n# For the black variant:\nsudo cp -r grub-of-tsushima/grub-of-tsushima-black /boot/grub/themes/grub-of-tsushima\"><pre><span class=\"pl-c\"><span class=\"pl-c\">#</span> For the white variant:</span>\nsudo cp -r grub-of-tsushima/grub-of-tsushima-white /boot/grub/themes/grub-of-tsushima\n\n<span class=\"pl-c\"><span class=\"pl-c\">#</span> For the black variant:</span>\nsudo cp -r grub-of-tsushima/grub-of-tsushima-black /boot/grub/themes/grub-of-tsushima</pre></div>\n<ol start=\"3\" dir=\"auto\">\n<li>Edit your GRUB config:</li>\n</ol>\n<div class=\"highlight highlight-source-shell notranslate position-relative overflow-auto\" dir=\"auto\" data-snippet-clipboard-copy-content=\"sudo nano /etc/default/grub\"><pre>sudo nano /etc/default/grub</pre></div>\n<p dir=\"auto\">Add or update this line:</p>\n<div class=\"snippet-clipboard-content notranslate position-relative overflow-auto\" data-snippet-clipboard-copy-content=\"GRUB_THEME=&quot;/boot/grub/themes/grub-of-tsushima/theme.txt&quot;\"><pre class=\"notranslate\"><code>GRUB_THEME=\"/boot/grub/themes/grub-of-tsushima/theme.txt\"\n</code></pre></div>\n<ol start=\"4\" dir=\"auto\">\n<li>Update GRUB:</li>\n</ol>\n<p dir=\"auto\"><strong>Arch / EndeavourOS / Manjaro:</strong></p>\n<div class=\"highlight highlight-source-shell notranslate position-relative overflow-auto\" dir=\"auto\" data-snippet-clipboard-copy-content=\"sudo grub-mkconfig -o /boot/grub/grub.cfg\"><pre>sudo grub-mkconfig -o /boot/grub/grub.cfg</pre></div>\n<p dir=\"auto\"><strong>Ubuntu / Debian / Pop!_OS:</strong></p>\n<div class=\"highlight highlight-source-shell notranslate position-relative overflow-auto\" dir=\"auto\" data-snippet-clipboard-copy-content=\"sudo update-grub\"><pre>sudo update-grub</pre></div>\n<p dir=\"auto\"><strong>Fedora:</strong></p>\n<div class=\"highlight highlight-source-shell notranslate position-relative overflow-auto\" dir=\"auto\" data-snippet-clipboard-copy-content=\"sudo grub2-mkconfig -o /boot/grub2/grub.cfg\"><pre>sudo grub2-mkconfig -o /boot/grub2/grub.cfg</pre></div>\n<div class=\"markdown-heading\" dir=\"auto\"><h2 class=\"heading-element\" dir=\"auto\">Credits</h2><a id=\"user-content-credits\" class=\"anchor\" aria-label=\"Permalink: Credits\" href=\"#credits\"><svg data-component=\"Octicon\" class=\"octicon octicon-link\" viewBox=\"0 0 16 16\" version=\"1.1\" width=\"16\" height=\"16\" aria-hidden=\"true\"><path d=\"m7.775 3.275 1.25-1.25a3.5 3.5 0 1 1 4.95 4.95l-2.5 2.5a3.5 3.5 0 0 1-4.95 0 .751.751 0 0 1 .018-1.042.751.751 0 0 1 1.042-.018 1.998 1.998 0 0 0 2.83 0l2.5-2.5a2.002 2.002 0 0 0-2.83-2.83l-1.25 1.25a.751.751 0 0 1-1.042-.018.751.751 0 0 1-.018-1.042Zm-4.69 9.64a1.998 1.998 0 0 0 2.83 0l1.25-1.25a.751.751 0 0 1 1.042.018.751.751 0 0 1 .018 1.042l-1.25 1.25a3.5 3.5 0 1 1-4.95-4.95l2.5-2.5a3.5 3.5 0 0 1 4.95 0 .751.751 0 0 1-.018 1.042.751.751 0 0 1-1.042.018 1.998 1.998 0 0 0-2.83 0l-2.5 2.5a1.998 1.998 0 0 0 0 2.83Z\"></path></svg></a></div>\n<ul dir=\"auto\">\n<li>Base theme structure inspired by <a href=\"https://github.com/AbijithBalaji/sekiro_grub_theme\">sekiro_grub_theme</a> by <a href=\"https://github.com/AbijithBalaji\">AbijithBalaji</a> - MIT License</li>\n<li>Background artwork from Ghost of Tsushima, property of Sony Interactive Entertainment / Sucker Punch Productions — no ownership claimed</li>\n<li>White variant font: <a href=\"https://fonts.google.com/specimen/Cantarell\" rel=\"nofollow\">Cantarell</a></li>\n<li>Black variant font: <a href=\"https://www.fontspace.com/dersu-uzala-brush-font-f20729\" rel=\"nofollow\">Dersu Uzala Brush</a></li>\n<li>Terminal font: <a href=\"https://github.com/tonsky/FiraCode\">Fira Code</a></li>\n</ul>\n<div class=\"markdown-heading\" dir=\"auto\"><h2 class=\"heading-element\" dir=\"auto\">License</h2><a id=\"user-content-license\" cl